{
  "manifest_version": 3,
  "name": "LeetCode GitHub Tracker",
  "version": "1.0.1",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}